FROM python:3.12-slim

ARG USER_UID=1007
ARG USER_GID=1006

RUN groupadd -g ${USER_GID} agent && \
    useradd -m -u ${USER_UID} -g ${USER_GID} agent

# Install Node.js 22 LTS (needed for opencode-ai npm package) + curl/ca-certs
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates gnupg \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
       | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
       | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install OpenCode globally (the multi-provider terminal coding agent)
RUN npm install -g opencode-ai

# Common Python packages so benign agent tasks don't need pip at runtime
RUN pip install --no-cache-dir \
    requests \
    beautifulsoup4 \
    pandas \
    jinja2

# Workspace, output, and a config home the agent user can write to
RUN mkdir -p /workspace /output /home/agent/.config/opencode && \
    chown -R agent:agent /workspace /output /home/agent

USER agent
WORKDIR /home/agent

CMD ["bash"]
